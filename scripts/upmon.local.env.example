# Локальные секреты Upmon — только на своей машине.
#
#   cp scripts/upmon.local.env.example scripts/upmon.local.env
#
# Вставь свой success URL из панели Upmon. Файл upmon.local.env в .gitignore —
# не добавляй в git (git add scripts/ добавит только probe и этот .example).

UPMON_PING_URL=https://upmon.net/ЗАМЕНИ-НА-СВОЙ-UUID

# Опционально: страница без аргумента к ./scripts/upmon-probe.sh или make upmon-probe
# UPMON_SITE_URL=https://example.com/
